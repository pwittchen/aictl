# ~/.aictl/config — aictl configuration file
# Copy this file to ~/.aictl/config (create the ~/.aictl directory first)
# and uncomment/fill in the values.


################################
#                              #
#         BASIC CONFIG         #
#                              #
################################


# Default provider and model (used when --provider / --model are not passed)
# AICTL_PROVIDER=anthropic
# AICTL_MODEL=claude-sonnet-4-20250514

# Thinking mode: smart (all messages) or fast (sliding window with recent messages)
# AICTL_THINKING=smart

# Incognito mode: when enabled, interactive REPL runs without saving sessions
# and /session is disabled (default: false). Accepted values: true, false.
# AICTL_INCOGNITO=false

# API keys
# LLM_OPENAI_API_KEY=sk-...
# LLM_ANTHROPIC_API_KEY=sk-ant-...
# LLM_GEMINI_API_KEY=...
# LLM_GROK_API_KEY=xai-...
# LLM_MISTRAL_API_KEY=...
# LLM_DEEPSEEK_API_KEY=sk-...
# LLM_ZAI_API_KEY=...

# Ollama (local models, no API key needed, optional - when it's not defined it falls back to the default host)
# LLM_OLLAMA_HOST=http://localhost:11434

# Web search (optional, used by web_search tool)
# FIRECRAWL_API_KEY=fc-...


################################
#                              #
#  SECURITY CONFIG (OPTIONAL)  #
#                              #
################################


# Security settings (all optional, sensible defaults apply)
# Master switch (default: true)
# AICTL_SECURITY=true

# Restrict file/directory tools to the current working directory (default: true)
# AICTL_SECURITY_CWD_RESTRICT=true

# Comma-separated whitelist of allowed shell commands (empty = all except blocked)
# AICTL_SECURITY_SHELL_ALLOWED=

# Comma-separated additional blocked shell commands (added to built-in defaults:
# rm, rmdir, mkfs, dd, shutdown, reboot, halt, poweroff, sudo, su, doas, eval, exec, nc, ncat, netcat)
# AICTL_SECURITY_SHELL_BLOCKED=

# Block $(), backticks, and process substitution in shell commands (default: true)
# AICTL_SECURITY_BLOCK_SUBSHELL=true

# Comma-separated additional blocked paths (added to built-in defaults:
# ~/.ssh, ~/.gnupg, ~/.aictl, ~/.aws, ~/.config/gcloud, /etc/shadow, /etc/sudoers)
# AICTL_SECURITY_BLOCKED_PATHS=

# Comma-separated paths allowed outside the working directory
# AICTL_SECURITY_ALLOWED_PATHS=/tmp/project-cache

# Shell command timeout in seconds (default: 30, 0 = unlimited)
# AICTL_SECURITY_SHELL_TIMEOUT=30

# Max file write size in bytes (default: 1048576 = 1 MB, 0 = unlimited)
# AICTL_SECURITY_MAX_WRITE=1048576

# Comma-separated tool names to disable (e.g. exec_shell,search_web)
# Available tools: exec_shell, read_file, write_file, remove_file, edit_file,
# list_directory, search_files, find_files, search_web, fetch_url,
# extract_website, fetch_datetime, fetch_geolocation
# AICTL_SECURITY_DISABLED_TOOLS=

# Comma-separated additional env vars to scrub from shell subprocesses
# (vars matching *_KEY, *_SECRET, *_TOKEN, *_PASSWORD are always scrubbed)
# AICTL_SECURITY_BLOCKED_ENV=
