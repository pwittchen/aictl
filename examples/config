# This is an exemplary config file

# ~/.aictl/config — aictl configuration file
# Copy this file to ~/.aictl/config (create the ~/.aictl directory first)
# and uncomment/fill in the values.

################################
#         BASIC CONFIG         #
################################

# Default provider and model (used when --provider / --model are not passed)
# Accepted providers: openai, anthropic, gemini, grok, mistral, deepseek,
# kimi, zai, ollama, gguf, mlx
# AICTL_PROVIDER=anthropic
# AICTL_MODEL=claude-sonnet-4-20250514

# Memory mode: long-term (all messages) or short-term (sliding window with recent messages)
# AICTL_MEMORY=long-term

# Incognito mode: when enabled, interactive REPL runs without saving sessions
# and /session is disabled (default: false). Accepted values: true, false.
# AICTL_INCOGNITO=false

# Project prompt file loaded from the current directory (default: AICTL.md)
# AICTL_PROMPT_FILE=AICTL.md

# Fallback chain for the project prompt file: when the file above is missing
# and this flag is enabled, aictl falls back to CLAUDE.md and then AGENTS.md
# (default: true). Accepted values: true, false.
# AICTL_PROMPT_FALLBACK=true

# Tools switch: when set to false, all tool calls are disabled and the LLM
# can only respond with plain text (default: true). Accepted values: true, false.
# AICTL_TOOLS_ENABLED=true

# Auto-compact threshold: context usage percentage at which the REPL
# automatically compacts the conversation (default: 80). Accepts 1..=100.
# AICTL_AUTO_COMPACT_THRESHOLD=80

# Per-call LLM timeout in seconds, applied uniformly to every provider
# (remote HTTP APIs, Ollama, native GGUF/MLX). Default: 30. Use 0 to disable.
# AICTL_LLM_TIMEOUT=30

# Maximum number of LLM calls allowed in a single agent turn before the loop
# terminates to prevent runaway tool-call cycles (default: 20, minimum: 1).
# AICTL_MAX_ITERATIONS=20

################################
#    API KEYS + OLLAMA HOST    #
################################

# LLM_OPENAI_API_KEY=sk-...
# LLM_ANTHROPIC_API_KEY=sk-ant-...
# LLM_GEMINI_API_KEY=...
# LLM_GROK_API_KEY=xai-...
# LLM_MISTRAL_API_KEY=...
# LLM_DEEPSEEK_API_KEY=sk-...
# LLM_KIMI_API_KEY=...
# LLM_ZAI_API_KEY=...

# Web search (optional, used by web_search tool)
# FIRECRAWL_API_KEY=fc-...

# Ollama (local models, no API key needed, optional - when it's not defined it falls back to the default host)
# LLM_OLLAMA_HOST=http://localhost:11434

################################
#  SECURITY CONFIG (OPTIONAL)  #
################################

# Security settings (all optional, sensible defaults apply)
# Master switch (default: true)
# AICTL_SECURITY=true

# Prompt injection guard: scans user input for patterns that try to override
# the system prompt, forge tool calls, or disable the security policy, and
# blocks the prompt when any match (default: true). Accepted values: true, false.
# AICTL_SECURITY_INJECTION_GUARD=true

# Restrict file/directory tools to the current working directory (default: true)
# AICTL_SECURITY_CWD_RESTRICT=true

# Comma-separated whitelist of allowed shell commands (empty = all except blocked)
# AICTL_SECURITY_SHELL_ALLOWED=

# Comma-separated additional blocked shell commands (added to built-in defaults:
# rm, rmdir, mkfs, dd, shutdown, reboot, halt, poweroff, sudo, su, doas, eval, exec, nc, ncat, netcat)
# AICTL_SECURITY_SHELL_BLOCKED=

# Block $(), backticks, and process substitution in shell commands (default: true)
# AICTL_SECURITY_BLOCK_SUBSHELL=true

# Comma-separated additional blocked paths (added to built-in defaults:
# ~/.ssh, ~/.gnupg, ~/.aictl, ~/.aws, ~/.config/gcloud, /etc/shadow, /etc/sudoers)
# AICTL_SECURITY_BLOCKED_PATHS=

# Comma-separated paths allowed outside the working directory
# AICTL_SECURITY_ALLOWED_PATHS=/tmp/project-cache

# Shell command timeout in seconds (default: 30, 0 = unlimited)
# AICTL_SECURITY_SHELL_TIMEOUT=30

# Max file write size in bytes (default: 1048576 = 1 MB, 0 = unlimited)
# AICTL_SECURITY_MAX_WRITE=1048576

# Comma-separated tool names to disable (e.g. exec_shell,search_web)
# Available tools: exec_shell, read_file, write_file, remove_file, create_directory,
# list_directory, search_files, edit_file, diff_files, find_files, search_web,
# fetch_url, extract_website, fetch_datetime, fetch_geolocation, read_image,
# generate_image, read_document, git, run_code, lint_file, json_query, calculate,
# csv_query, list_processes, check_port, system_info, archive, checksum, clipboard,
# notify
# AICTL_SECURITY_DISABLED_TOOLS=

# Comma-separated additional env vars to scrub from shell subprocesses
# (vars matching *_KEY, *_SECRET, *_TOKEN, *_PASSWORD are always scrubbed)
# AICTL_SECURITY_BLOCKED_ENV=

# Audit log: append one JSON line per tool invocation to
# ~/.aictl/audit/<session-id> (JSONL) with timestamp, tool, truncated input,
# and an outcome tag (executed / denied_by_policy / denied_by_user /
# disabled / duplicate). The filename mirrors the session file under
# ~/.aictl/sessions/. Skipped in incognito mode and single-shot runs.
# Observability-only, so --unrestricted leaves it on (default: true).
# Accepted values: true, false.
# AICTL_SECURITY_AUDIT_LOG=true

################################
#  REDACTION (OPTIONAL, OFF)   #
################################

# Sensitive-data redaction at the network boundary. Inspects every
# outbound message (and tool result on its way back through) for
# credentials and PII before it reaches a remote provider. The
# persisted session file under ~/.aictl/sessions/ always keeps the
# original text — redaction is a wire-level control, not a storage
# one. Every redaction / block event is recorded to the per-session
# audit log alongside tool calls.
#
# Mode: off (default — pure pass-through), redact (swap each match
# for [REDACTED:<KIND>] on the wire), or block (abort the turn with
# a scrubbed error naming the detected kinds).
# AICTL_SECURITY_REDACTION=off

# Also redact when sending to local providers (ollama, gguf, mlx).
# Default false — data never leaves the machine for these, so
# there's no privacy gain, just latency. Flip to true if you want
# to smoke-test your config against a local model before switching
# to a remote one. Accepted values: true, false.
# AICTL_SECURITY_REDACTION_LOCAL=false

# Subset of built-in detectors to run. Empty/unset = all of them.
# Slugs: api_key, aws, jwt, private_key, connection_string,
#        credit_card, iban, email, phone, high_entropy
# AICTL_REDACTION_DETECTORS=api_key,aws,jwt,private_key,connection_string

# User-defined patterns as NAME=REGEX pairs, semicolon-separated.
# NAME becomes the placeholder suffix: [REDACTED:CUSTOMER_ID].
# Bad regexes print a warning at startup and are skipped.
# AICTL_REDACTION_EXTRA_PATTERNS=CUSTOMER_ID=CUST-\d{8};TICKET=JIRA-\d{4,}

# Allowlist — semicolon-separated regexes. Any detection whose span
# is covered by an allowlist hit is dropped before redaction or
# blocking. Useful for documentation examples, known-good hashes,
# or internal identifiers that trip the entropy scanner.
# AICTL_REDACTION_ALLOW=AKIAIOSFODNN7EXAMPLE;example\.com

# Optional Layer-C Named Entity Recognition (NER) pass for person
# names, locations, and organizations. Requires:
#   1. a build with the `redaction-ner` cargo feature
#      (`cargo build --features redaction-ner`), and
#   2. a pulled NER model at ~/.aictl/models/ner/<name>/.
# Without (1), aictl prints a startup warning and falls back to
# Layers A + B. Pull a model with:
#   aictl --pull-ner-model onnx-community/gliner_small-v2.1
# List, remove, or clear models with --list-ner-models,
# --remove-ner-model <NAME>, --clear-ner-models.
# Accepted values: true, false.
# AICTL_REDACTION_NER=false

# Name of the NER model to use when AICTL_REDACTION_NER=true.
# Default: onnx-community/gliner_small-v2.1. The local name is
# derived from the repo segment, so the model loads from
# ~/.aictl/models/ner/gliner_small-v2.1/.
# AICTL_REDACTION_NER_MODEL=onnx-community/gliner_small-v2.1

################################
#   PLUGINS (OPTIONAL, OFF)    #
################################

# User-installable plugin tools. A plugin is a directory under
# ~/.aictl/plugins/<name>/ containing a `plugin.toml` manifest plus
# an executable entrypoint (any language — script or binary). The
# raw <tool>...</tool> body is piped to stdin; stdout is returned to
# the model verbatim; non-zero exit surfaces as `[exit N] <stderr>`.
# Discovery happens once at startup — restart aictl to pick up new
# plugins. The standard security gate (CWD jail, disabled-tools
# list, confirmation prompt) still fronts every plugin call.
#
# Master switch: plugins are third-party code and must not auto-load.
# Set to true to opt in (default: false). Accepted values: true, false.
# AICTL_PLUGINS_ENABLED=false

# Override the discovery root (default: ~/.aictl/plugins). Used
# mainly by tests and isolated installs.
# AICTL_PLUGINS_DIR=

# Comma-separated plugin names to skip at load time. Useful for
# silencing one third-party plugin without editing its manifest.
# AICTL_PLUGINS_DISABLED=
